generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int       @id         @default(autoincrement())
  username    String    @unique
  password    String
  todos       Todo[]
}

model Todo {
  id            Int     @id       @default(autoincrement())
  title         String
  description   String
  userId        Int
  user          User    @relation(fields: [userId], references: [id])
}